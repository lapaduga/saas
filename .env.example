# LLM Provider: deepseek или local
LLM_PROVIDER=deepseek

# DeepSeek (облачный провайдер)
# Вставьте ваш API-ключ DeepSeek (получите на https://platform.deepseek.com)
CHAT_API_KEY=your-key-here
CHAT_MODEL=deepseek-v4-pro
CHAT_BASE_URL=https://api.deepseek.com

# Локальная модель эмбеддингов
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=20

# Сервер
PORT=3000
HOST=0.0.0.0

# БД
DB_PATH=./data/support.db
